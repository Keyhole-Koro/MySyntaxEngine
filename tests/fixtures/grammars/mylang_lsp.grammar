%scope L_BRACE R_BRACE

program     : topList $
            | $

topList     : topList top
            | top

top         : packageDecl
            | importDecl
            | testDecl
            | exportDecl
            | externDecl
            | typedefStmt
            | structDecl
            | enumDecl
            | varDecl
            | funcDecl

packageDecl : 'PACKAGE' 'IDENTIFIER'@namespace 'SEMICOLON'

importDecl  : 'IMPORT' 'IDENTIFIER'@namespace 'SEMICOLON'
            | 'IMPORT' 'IDENTIFIER'@namespace 'FROM' 'STRING_LITERAL' 'SEMICOLON'
            | 'IMPORT' 'L_BRACE' identifierList 'R_BRACE' 'FROM' 'STRING_LITERAL' 'SEMICOLON'

testDecl    : 'IDENTIFIER'@function 'L_PARENTHESES' 'STRING_LITERAL' 'COMMA' testOptions 'COMMA' testBody 'R_PARENTHESES' 'SEMICOLON'

testOptions : 'L_BRACE' 'R_BRACE'
            | 'L_BRACE' testOptionList 'R_BRACE'

testOptionList: testOptionList testOption
            | testOption

testOption  : 'IDENTIFIER'@property 'COLON' expr 'SEMICOLON'

testBody    : 'L_PARENTHESES' 'R_PARENTHESES' 'FAT_ARROW' block

exportDecl  : 'EXPORT' exportable

exportable  : typedefStmt
            | structDecl
            | enumDecl
            | varDecl
            | funcDecl

externDecl  : 'EXTERN' varDecl
            | 'EXTERN' funcProto

typedefStmt : 'TYPEDEF' type 'IDENTIFIER'@type@decl(type) 'SEMICOLON'
            | 'TYPEDEF' structDecl

structDecl  : 'STRUCT' 'IDENTIFIER'@struct@decl(struct) 'L_BRACE' 'R_BRACE' 'SEMICOLON'
            | 'STRUCT' 'IDENTIFIER'@struct@decl(struct) 'L_BRACE' fieldList 'R_BRACE' 'SEMICOLON'
            | 'STRUCT' 'L_BRACE' fieldList 'R_BRACE' 'IDENTIFIER'@struct@decl(struct) 'SEMICOLON'

fieldList   : fieldList varDecl
            | varDecl

enumDecl    : 'ENUM' 'IDENTIFIER'@struct@decl(enum) 'L_BRACE' enumItems 'R_BRACE' 'SEMICOLON'
            | 'ENUM' 'IDENTIFIER'@struct@decl(enum) 'L_BRACE' enumItems 'COMMA' 'R_BRACE' 'SEMICOLON'

enumItems   : enumItems 'COMMA' enumItem
            | enumItem

enumItem    : 'IDENTIFIER'@enumMember@decl(enumMember)
            | 'IDENTIFIER'@enumMember@decl(enumMember) 'ASSIGN' 'NUMBER'

funcDecl    : funcDef
            | funcProto

funcProto   : type 'IDENTIFIER'@function@decl(function) 'L_PARENTHESES' 'R_PARENTHESES' 'SEMICOLON'
            | type 'IDENTIFIER'@function@decl(function) 'L_PARENTHESES' paramList 'R_PARENTHESES' 'SEMICOLON'

funcDef     : type 'IDENTIFIER'@function@decl(function) 'L_PARENTHESES' 'R_PARENTHESES' block
            | type 'IDENTIFIER'@function@decl(function) 'L_PARENTHESES' paramList 'R_PARENTHESES' block

paramList   : paramList 'COMMA' param
            | paramList 'COMMA' restParam
            | param
            | restParam

param       : type declarator@parameter
            | 'MUT' type declarator@parameter

restParam   : 'REST' 'IDENTIFIER'@parameter

varDecl     : type declarator@variable@decl(variable) 'SEMICOLON'
            | type declarator@variable@decl(variable) 'ASSIGN' expr 'SEMICOLON'
            | type declarator@variable@decl(variable) 'ASSIGN' initList 'SEMICOLON'
            | 'MUT' type declarator@variable@decl(variable) 'SEMICOLON'
            | 'MUT' type declarator@variable@decl(variable) 'ASSIGN' expr 'SEMICOLON'
            | 'MUT' type declarator@variable@decl(variable) 'ASSIGN' initList 'SEMICOLON'

declarator  : 'IDENTIFIER'
            | declarator arraySuffix

arraySuffix : 'L_BRACKET' 'R_BRACKET'
            | 'L_BRACKET' 'NUMBER' 'R_BRACKET'

initList    : 'L_BRACE' exprList 'R_BRACE'
            | 'L_BRACE' exprList 'COMMA' 'R_BRACE'

block       : 'L_BRACE' 'R_BRACE'
            | 'L_BRACE' stmtList 'R_BRACE'

stmtList    : stmtList stmt
            | stmt

stmt        : matchedStmt
            | unmatchedStmt

matchedStmt : simpleStmt
            | 'IF' 'L_PARENTHESES' expr 'R_PARENTHESES' matchedStmt 'ELSE' matchedStmt
            | 'WHILE' 'L_PARENTHESES' expr 'R_PARENTHESES' matchedStmt
            | forHeader matchedStmt

unmatchedStmt: 'IF' 'L_PARENTHESES' expr 'R_PARENTHESES' stmt
            | 'IF' 'L_PARENTHESES' expr 'R_PARENTHESES' matchedStmt 'ELSE' unmatchedStmt
            | 'WHILE' 'L_PARENTHESES' expr 'R_PARENTHESES' unmatchedStmt
            | forHeader unmatchedStmt

simpleStmt  : block
            | varDecl
            | doWhileStmt
            | returnStmt
            | breakStmt
            | continueStmt
            | yieldStmt
            | uncheckedStmt
            | expr 'SEMICOLON'
            | 'SEMICOLON'

doWhileStmt : 'DO' stmt 'WHILE' 'L_PARENTHESES' expr 'R_PARENTHESES' 'SEMICOLON'

forHeader   : 'FOR' 'L_PARENTHESES' forInit 'SEMICOLON' forExpr 'SEMICOLON' forExpr 'R_PARENTHESES'
            | 'FOR' 'L_PARENTHESES' forInit 'SEMICOLON' forExpr 'SEMICOLON' 'R_PARENTHESES'
            | 'FOR' 'L_PARENTHESES' forInit 'SEMICOLON' 'SEMICOLON' forExpr 'R_PARENTHESES'
            | 'FOR' 'L_PARENTHESES' forInit 'SEMICOLON' 'SEMICOLON' 'R_PARENTHESES'
            | 'FOR' 'L_PARENTHESES' 'SEMICOLON' forExpr 'SEMICOLON' forExpr 'R_PARENTHESES'
            | 'FOR' 'L_PARENTHESES' 'SEMICOLON' forExpr 'SEMICOLON' 'R_PARENTHESES'
            | 'FOR' 'L_PARENTHESES' 'SEMICOLON' 'SEMICOLON' forExpr 'R_PARENTHESES'
            | 'FOR' 'L_PARENTHESES' 'SEMICOLON' 'SEMICOLON' 'R_PARENTHESES'

forInit     : type declarator@variable
            | type declarator@variable 'ASSIGN' expr
            | 'MUT' type declarator@variable
            | 'MUT' type declarator@variable 'ASSIGN' expr
            | expr

forExpr     : expr

returnStmt  : 'RETURN' 'SEMICOLON'
            | 'RETURN' expr 'SEMICOLON'

breakStmt   : 'BREAK' 'SEMICOLON'

continueStmt: 'CONTINUE' 'SEMICOLON'

yieldStmt   : 'YIELD' expr 'SEMICOLON'

uncheckedStmt: 'UNCHECKED' block

type        : typePrefix baseType ptrList
            | typePrefix baseType
            | baseType ptrList
            | baseType

typePrefix  : 'CONST'
            | 'REF'
            | 'REF' 'MUT'
            | 'CONST' 'REF'
            | 'CONST' 'REF' 'MUT'

ptrList     : ptrList 'ASTARISK'
            | 'ASTARISK'

baseType    : primitiveType
            | 'IDENTIFIER'@type

primitiveType: 'BOOL'
            | 'U8'
            | 'U16'
            | 'I32'
            | 'U32'
            | 'CHAR'
            | 'FLOAT'
            | 'DOUBLE'
            | 'VOID'
            | 'LONG'
            | 'SHORT'

exprList    : exprList 'COMMA' expr
            | expr

expr        : assignExpr

assignExpr  : unaryExpr 'ASSIGN' assignExpr
            | logicalOrExpr

logicalOrExpr: logicalOrExpr 'OR' logicalAndExpr
            | logicalAndExpr

logicalAndExpr: logicalAndExpr 'AND' bitOrExpr
            | bitOrExpr

bitOrExpr   : bitOrExpr 'BITOR' bitXorExpr
            | bitXorExpr

bitXorExpr  : bitXorExpr 'BITXOR' bitAndExpr
            | bitAndExpr

bitAndExpr  : bitAndExpr 'AMPERSAND' equalityExpr
            | equalityExpr

equalityExpr: equalityExpr equalityOp relationalExpr
            | relationalExpr

equalityOp  : 'EQ'
            | 'NEQ'

relationalExpr: relationalExpr relationalOp shiftExpr
            | shiftExpr

relationalOp: 'LT'
            | 'GT'
            | 'LTE'
            | 'GTE'

shiftExpr   : shiftExpr shiftOp addExpr
            | addExpr

shiftOp     : 'LSH'
            | 'RSH'

addExpr     : addExpr addOp mulExpr
            | mulExpr

addOp       : 'ADD'
            | 'SUB'

mulExpr     : mulExpr mulOp unaryExpr
            | unaryExpr

mulOp       : 'ASTARISK'
            | 'DIV'
            | 'MOD'

unaryExpr   : castExpr
            | unaryOp unaryExpr
            | postfixExpr

castExpr    : 'L_PARENTHESES' castType 'R_PARENTHESES' unaryExpr

castType    : typePrefix primitiveType ptrList
            | typePrefix primitiveType
            | primitiveType ptrList
            | primitiveType

unaryOp     : 'NOT'
            | 'BITNOT'
            | 'SUB'
            | 'ADD'
            | 'ASTARISK'
            | 'AMPERSAND'
            | 'INC'
            | 'DEC'
            | 'SIZEOF'

postfixExpr : primary
            | postfixExpr 'INC'
            | postfixExpr 'DEC'
            | postfixExpr 'DOT' 'IDENTIFIER'@property
            | postfixExpr 'MEMBER' 'IDENTIFIER'@property
            | postfixExpr 'L_BRACKET' expr 'R_BRACKET'
            | postfixExpr@function:single 'L_PARENTHESES' 'R_PARENTHESES'
            | postfixExpr@function:single 'L_PARENTHESES' argList 'R_PARENTHESES'

argList     : argList 'COMMA' expr
            | expr

primary     : 'IDENTIFIER'@variable
            | 'NUMBER'
            | 'STRING_LITERAL'
            | 'CHAR_LITERAL'
            | funLiteral
            | 'L_PARENTHESES' expr 'R_PARENTHESES'

funLiteral  : 'L_PARENTHESES' 'R_PARENTHESES' 'FAT_ARROW' block
            | 'L_PARENTHESES' funParamList 'R_PARENTHESES' 'FAT_ARROW' block

funParamList: funParamList 'COMMA' funParam
            | funParam

funParam    : funType declarator@parameter
            | 'MUT' funType declarator@parameter

funType     : typePrefix primitiveType ptrList
            | typePrefix primitiveType
            | primitiveType ptrList
            | primitiveType

identifierList: identifierList 'COMMA' 'IDENTIFIER'
            | 'IDENTIFIER'
